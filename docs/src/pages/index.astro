---
import Layout from '../layouts/Layout.astro';

import { readFileSync } from 'node:fs';

const pubspecContent = readFileSync(new URL('../../../pubspec.yaml', import.meta.url), 'utf-8');
const versionMatch = pubspecContent.match(/^version:\s*([^\s]+)/m);
const fallbackVersion = versionMatch?.[1] ?? '0.0.0';
---

<Layout title="BiCone — Bilibili 防失效追更工具">
  <!-- Navigation -->
  <nav class="fixed top-0 left-0 right-0 z-50 backdrop-blur-xl bg-white/70 border-b border-black/5 transition-all">
    <div class="max-w-6xl mx-auto px-6 h-14 flex items-center justify-between">
      <a href="#" class="flex items-center gap-2.5 text-text-primary font-bold text-lg tracking-tight">
        <img src={`${import.meta.env.BASE_URL}icon.png`} alt="BiCone" class="w-7 h-7 rounded-md" />
        BiCone
      </a>
      <div class="hidden sm:flex items-center gap-8 text-sm font-medium text-text-secondary">
        <a href="#features" class="hover:text-text-primary transition-colors">功能</a>
        <a href="#quickstart" class="hover:text-text-primary transition-colors">快速上手</a>
        <a href="#download" class="inline-flex items-center justify-center px-4 py-1.5 bg-text-primary text-white rounded-full hover:bg-black/80 transition-transform hover:scale-105 active:scale-95 shadow-xs">
          免费下载
        </a>
      </div>
    </div>
  </nav>

  <!-- Hero Section -->
  <section class="relative pt-36 pb-20 sm:pt-48 sm:pb-24 overflow-hidden flex flex-col items-center bg-white">
    <div class="text-center px-6 reveal-up z-10">
      <h1 class="text-4xl sm:text-5xl md:text-7xl font-extrabold tracking-tight text-text-primary leading-[1.15] sm:leading-[1.1]">
        你关注的精彩
        <br />
        <span class="bg-clip-text text-transparent bg-linear-to-r from-bilipink to-purple-500">一集不落</span>
      </h1>
      <p class="mt-6 text-xl sm:text-2xl text-text-secondary font-medium tracking-tight max-w-2xl mx-auto">
        订阅、通知、缓存，一切自动完成。
      </p>
      <div class="mt-10 flex flex-col sm:flex-row items-center justify-center gap-4">
        <a href="#download" class="inline-flex items-center justify-center px-7 py-3.5 bg-text-primary text-white rounded-full text-sm font-semibold hover:bg-black/80 hover:shadow-lg transition-all hover:scale-105 active:scale-95 dark">
          立即下载
        </a>
        <div class="flex items-center gap-3">
          <a href="https://github.com/IT-Bill/BiCone" target="_blank" rel="noopener noreferrer" class="inline-flex items-center justify-center gap-2 px-7 py-3.5 bg-[#F5F5F7] text-text-primary rounded-full text-sm font-semibold hover:bg-[#E5E5E7] transition-all">
            <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor">
              <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z" />
            </svg>
            GitHub
          </a>
          <a href="https://gitee.com/IT-Bill/BiCone" target="_blank" rel="noopener noreferrer" class="inline-flex items-center justify-center gap-2 px-7 py-3.5 bg-[#F5F5F7] text-text-primary rounded-full text-sm font-semibold hover:bg-[#E5E5E7] transition-all">
            <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor">
              <path d="M11.984 0A12 12 0 0 0 0 12a12 12 0 0 0 12 12 12 12 0 0 0 12-12A12 12 0 0 0 12 0a12 12 0 0 0-.016 0zm6.09 5.333c.328 0 .593.266.592.593v1.482a.594.594 0 0 1-.593.592H9.777c-.982 0-1.778.796-1.778 1.778v5.63c0 .327.266.592.593.592h5.63c.982 0 1.778-.796 1.778-1.778v-.296a.593.593 0 0 0-.592-.593h-4.15a.59.59 0 0 1-.592-.592v-1.482a.593.593 0 0 1 .593-.592h6.815c.327 0 .593.265.593.592v3.408a4 4 0 0 1-4 4H8.37a.593.593 0 0 1-.593-.593V9.778a4.444 4.444 0 0 1 4.445-4.444h5.852z" />
            </svg>
            Gitee
          </a>
        </div>
      </div>
    </div>

    <!-- Minimalist Mockup container -->
    <div class="mt-16 sm:mt-24 px-6 w-full max-w-5xl reveal-up" style="transition-delay: 150ms;">
      <div class="relative rounded-2xl sm:rounded-4xl bg-[#F5F5F7] p-2 sm:p-4 shadow-[0_30px_60px_rgba(0,0,0,0.08)] border border-black/5 overflow-hidden">
        <!-- inner screen -->
        <div class="rounded-xl sm:rounded-2xl overflow-hidden bg-white aspect-video relative flex items-center justify-center">
            <video class="w-full h-full object-cover" autoplay muted playsinline loop>
                <source src={`${import.meta.env.BASE_URL}videos/step4.mp4`} type="video/mp4" />
            </video>
            <!-- mock top bar -->
            <div class="absolute top-0 left-0 right-0 h-8 sm:h-10 md:h-12 bg-white/70 backdrop-blur-md flex items-center px-3 sm:px-4 gap-1.5 sm:gap-2 border-b border-black/5">
                <div class="w-3 h-3 rounded-full bg-[#ff5f56]"></div>
                <div class="w-3 h-3 rounded-full bg-[#ffbd2e]"></div>
                <div class="w-3 h-3 rounded-full bg-[#27c93f]"></div>
            </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Features (Bento Box) Section -->
  <section id="features" class="py-24 sm:py-32 bg-white">
    <div class="max-w-6xl mx-auto px-6">
      <div class="mb-16 text-center reveal-up">
        <h2 class="text-4xl sm:text-5xl font-bold tracking-tight text-text-primary">把精彩，存进本地</h2>
        <p class="mt-4 text-xl text-text-secondary">为 B 站量身打造的最佳缓存体验</p>
      </div>

      <!-- Bento Grid -->
      <div class="grid grid-cols-1 md:grid-cols-3 gap-5 sm:gap-6 auto-rows-[25rem] sm:auto-rows-[28rem]">
          <!-- Card 1: Auto Subscribe (Large) -->
          <div class="md:col-span-2 rounded-4xl bg-[#F5F5F7] p-8 sm:p-10 relative overflow-hidden group reveal-up transition-colors hover:bg-[#EAEAEA]">
              <div class="relative z-10">
                  <h3 class="text-2xl sm:text-3xl font-bold text-text-primary tracking-tight">自动追踪</h3>
                  <p class="text-text-secondary mt-2 sm:mt-3 text-base sm:text-lg max-w-sm font-medium">输入 UP 主 UID，剩下的全交给我们。全自动订阅，精准不漏更。</p>
              </div>
              <div class="absolute -bottom-[5%] -right-[5%] w-[80%] md:w-[60%] aspect-video bg-white rounded-tl-2xl shadow-[0_20px_40px_rgba(0,0,0,0.1)] border border-black/5 overflow-hidden transition-transform duration-700 ease-out group-hover:-translate-y-4 group-hover:-translate-x-4">
                  <img src={`${import.meta.env.BASE_URL}subscribe.jpg`} alt="自动追踪订阅" class="w-full h-full object-cover" />
              </div>
          </div>

          <!-- Card 2: Background Cache (Medium) -->
          <div class="md:col-span-1 rounded-4xl bg-[#F5F5F7] p-8 sm:p-10 flex flex-col relative overflow-hidden group reveal-up transition-colors hover:bg-[#EAEAEA]" style="transition-delay: 100ms;">
              <div class="relative z-10">
                  <h3 class="text-2xl sm:text-3xl font-bold text-text-primary tracking-tight">静默缓存</h3>
                  <p class="text-text-secondary mt-2 sm:mt-3 text-base sm:text-lg font-medium">检测到更新，即刻在后台下载至本地，从源头告别失效问题。</p>
              </div>
              <div class="grow flex items-end mt-6 translate-y-4 group-hover:translate-y-0 transition-transform duration-700 ease-out relative z-10">
                  <img src={`${import.meta.env.BASE_URL}download.jpg`} alt="静默缓存" class="w-full rounded-xl shadow-[0_10px_30px_rgba(0,0,0,0.08)] border border-black/5" />
              </div>
          </div>

          <!-- Card 3: Notifications -->
            <div class="md:col-span-1 rounded-4xl bg-[#F5F5F7] p-8 sm:p-10 flex flex-col reveal-up transition-colors hover:bg-[#EAEAEA]" style="transition-delay: 0ms;">
              <h3 class="text-2xl font-bold text-text-primary tracking-tight">更新通知</h3>
              <p class="text-text-secondary mt-2 sm:mt-3 text-base sm:text-lg font-medium">无需反复刷新。新视频发布即刻推送，第一时间掌握动态。</p>
              <div class="grow flex items-end">
                <div class="w-full bg-white rounded-xl p-4 shadow-sm border border-black/5 flex items-center gap-4">
                  <div class="w-10 h-10 rounded-full bg-bilipink/10 flex items-center justify-center shrink-0">
                    <svg class="w-5 h-5 text-bilipink" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M14.857 17.082a23.848 23.848 0 005.454-1.31A8.967 8.967 0 0118 9.75v-.7V9A6 6 0 006 9v.75a8.967 8.967 0 01-2.312 6.022c1.733.64 3.56 1.085 5.455 1.31m5.714 0a24.255 24.255 0 01-5.714 0m5.714 0a3 3 0 11-5.714 0" />
                    </svg>
                  </div>
                  <div>
                    <div class="text-sm font-semibold text-text-primary">UP主 发布了新视频！</div>
                    <div class="text-xs text-text-secondary line-clamp-1 mt-0.5">自动下载已开始...</div>
                  </div>
                </div>
              </div>
          </div>

          <!-- Card 4: Quality & Speed -->
            <div class="md:col-span-1 rounded-4xl bg-[#F5F5F7] p-8 sm:p-10 flex flex-col reveal-up transition-colors hover:bg-[#EAEAEA]" style="transition-delay: 100ms;">
              <h3 class="text-2xl font-bold text-text-primary tracking-tight">多画质与速度</h3>
              <p class="text-text-secondary mt-2 sm:mt-3 text-base sm:text-lg font-medium">自选 360P 至 4K 原画。多线程拉取，畅享极速下载体验。</p>
              <div class="grow flex items-end">
                <div class="flex flex-wrap gap-2">
                  <span class="px-3 py-1 bg-white border border-black/5 rounded-full text-sm font-semibold text-text-primary shadow-sm">4K 原画</span>
                  <span class="px-3 py-1 bg-white border border-black/5 rounded-full text-sm font-semibold text-text-primary shadow-sm">1080P 高帧率</span>
                  <span class="px-3 py-1 bg-white border border-black/5 rounded-full text-sm font-semibold text-text-primary shadow-sm">多线程提升</span>
                </div>
              </div>
          </div>

          <!-- Card 5: Cross-platform -->
            <div class="md:col-span-1 rounded-4xl bg-[#F5F5F7] p-8 sm:p-10 flex flex-col reveal-up transition-colors hover:bg-[#EAEAEA]" style="transition-delay: 200ms;">
              <h3 class="text-2xl font-bold text-text-primary tracking-tight">跨平台支持</h3>
              <p class="text-text-secondary mt-2 sm:mt-3 text-base sm:text-lg font-medium">无缝适配 Android、iOS 与 Windows，体验一致，随处可用。</p>
              <div class="grow flex items-end justify-between px-2">
                <svg class="w-16 h-16 text-text-tertiary/40" viewBox="93.5 36.5 280 280" fill="currentColor" xmlns="http://www.w3.org/2000/svg">
                  <path d="M293.91 212.775c-6.025 0-10.926-4.905-10.926-10.93 0-6.025 4.901-10.926 10.926-10.926 6.026 0 10.927 4.9 10.927 10.926 0 6.025-4.901 10.93-10.927 10.93m-120.774 0c-6.025 0-10.926-4.905-10.926-10.93 0-6.025 4.9-10.926 10.926-10.926 6.025 0 10.926 4.9 10.926 10.926 0 6.025-4.9 10.93-10.926 10.93m124.693-65.82l21.838-37.822a4.548 4.548 0 00-1.663-6.206 4.549 4.549 0 00-6.206 1.663l-22.111 38.3c-16.91-7.716-35.9-12.015-56.164-12.015-20.264 0-39.254 4.299-56.163 12.015l-22.112-38.3a4.549 4.549 0 00-6.206-1.663 4.545 4.545 0 00-1.663 6.206l21.838 37.822c-37.499 20.395-63.146 58.358-66.898 103.209h262.408c-3.755-44.85-29.402-82.814-66.898-103.21" />
                </svg>
                <div class="w-0.5 h-10 bg-black/5 rounded-full"></div>
                <svg class="w-14 h-14 text-text-tertiary/40" viewBox="0 0 24 24" fill="currentColor">
                  <path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z" />
                </svg>
                <div class="w-0.5 h-10 bg-black/5 rounded-full"></div>
                <svg class="w-14 h-14 text-text-tertiary/40" viewBox="0 0 24 24" fill="currentColor">
                  <path d="M0 3.449L9.75 2.1v9.451H0m10.949-9.602L24 0v11.4H10.949M0 12.6h9.75v9.451L0 20.699M10.949 12.6H24V24l-12.9-1.801" />
                </svg>
              </div>
          </div>
      </div>
    </div>
  </section>

  <!-- How it works (Z-Layout) -->
  <section id="quickstart" class="py-24 sm:py-40 bg-white border-t border-black/5">
    <div class="max-w-6xl mx-auto px-6">
      <div class="text-center mb-20 sm:mb-32 reveal-up">
        <h2 class="text-4xl sm:text-5xl md:text-6xl font-bold tracking-tight text-text-primary">
          <span class="block sm:inline">四步即刻开启</span><span class="hidden sm:inline">，</span>
          <span class="block sm:inline">享受无感追更</span>
        </h2>
      </div>

      <div class="flex flex-col gap-16 sm:gap-40">
        <!-- Step 1 -->
        <div class="flex flex-col md:flex-row items-center justify-between gap-12 sm:gap-20 reveal-up">
          <div class="w-full md:w-5/12 text-center md:text-left">
            <span class="text-text-tertiary font-bold tracking-widest uppercase text-sm mb-4 block">STEP 1</span>
            <h3 class="text-3xl sm:text-5xl font-bold text-text-primary tracking-tight mb-4 sm:mb-6">扫码登录</h3>
            <p class="text-lg sm:text-xl text-text-secondary leading-relaxed font-medium">使用 Bilibili 手机客户端安全扫码，本地授权获取内容解析权限。</p>
          </div>
          <div class="w-full md:w-7/12">
            <div class="rounded-4xl bg-[#F5F5F7] aspect-3/4 sm:aspect-4/3 flex items-center justify-center p-6 sm:p-8 overflow-hidden">
              <div class="h-full aspect-12/25 rounded-2xl overflow-hidden shadow-[0_20px_40px_rgba(0,0,0,0.1)] border border-black/5 bg-white relative">
                <video class="w-full h-full object-cover" autoplay muted playsinline loop poster={`${import.meta.env.BASE_URL}videos/step1-poster.svg`}>
                  <source src={`${import.meta.env.BASE_URL}videos/step1.mp4`} type="video/mp4" />
                </video>
              </div>
            </div>
          </div>
        </div>

        <!-- Step 2 -->
        <div class="flex flex-col md:flex-row-reverse items-center justify-between gap-12 sm:gap-20 reveal-up">
          <div class="w-full md:w-5/12 text-center md:text-left">
            <span class="text-text-tertiary font-bold tracking-widest uppercase text-sm mb-4 block">STEP 2</span>
            <h3 class="text-3xl sm:text-5xl font-bold text-text-primary tracking-tight mb-4 sm:mb-6">添加订阅</h3>
            <p class="text-lg sm:text-xl text-text-secondary leading-relaxed font-medium">输入想监测的 UP 主 UID。只需一次操作，以后的每一次更新尽在掌握。</p>
          </div>
          <div class="w-full md:w-7/12">
            <div class="rounded-4xl bg-[#F5F5F7] aspect-3/4 sm:aspect-4/3 flex items-center justify-center p-6 sm:p-8 overflow-hidden">
              <div class="h-full aspect-12/25 rounded-2xl overflow-hidden shadow-[0_20px_40px_rgba(0,0,0,0.1)] border border-black/5 bg-white relative">
                <video class="w-full h-full object-cover" autoplay muted playsinline loop poster={`${import.meta.env.BASE_URL}videos/step2-poster.svg`}>
                  <source src={`${import.meta.env.BASE_URL}videos/step2.mp4`} type="video/mp4" />
                </video>
              </div>
            </div>
          </div>
        </div>

        <!-- Step 3 -->
        <div class="flex flex-col md:flex-row items-center justify-between gap-12 sm:gap-20 reveal-up">
          <div class="w-full md:w-5/12 text-center md:text-left">
            <span class="text-text-tertiary font-bold tracking-widest uppercase text-sm mb-4 block">STEP 3</span>
            <h3 class="text-3xl sm:text-5xl font-bold text-text-primary tracking-tight mb-4 sm:mb-6">后台驻留</h3>
            <p class="text-lg sm:text-xl text-text-secondary leading-relaxed font-medium">为 App 开启无限制后台权限。它像系统服务一样静默运行，甚至感受不到它的存在。</p>
          </div>
          <div class="w-full md:w-7/12">
            <div class="rounded-4xl bg-[#F5F5F7] aspect-3/4 sm:aspect-4/3 flex items-center justify-center p-6 sm:p-8 overflow-hidden">
              <div class="h-full aspect-12/25 rounded-2xl overflow-hidden shadow-[0_20px_40px_rgba(0,0,0,0.1)] border border-black/5 bg-white relative">
                <video class="w-full h-full object-cover" autoplay muted playsinline loop poster={`${import.meta.env.BASE_URL}videos/step3-poster.svg`}>
                  <source src={`${import.meta.env.BASE_URL}videos/step3.mp4`} type="video/mp4" />
                </video>
              </div>
            </div>
          </div>
        </div>

        <!-- Step 4 -->
        <div class="flex flex-col md:flex-row-reverse items-center justify-between gap-12 sm:gap-20 reveal-up">
          <div class="w-full md:w-5/12 text-center md:text-left">
            <span class="text-text-tertiary font-bold tracking-widest uppercase text-sm mb-4 block">STEP 4</span>
            <h3 class="text-3xl sm:text-5xl font-bold text-text-primary tracking-tight mb-4 sm:mb-6">无感更新</h3>
            <p class="text-lg sm:text-xl text-text-secondary leading-relaxed font-medium">全自动下载完毕，随时点开观看。不再等待，彻底告别视频下架的遗憾。</p>
          </div>
          <div class="w-full md:w-7/12">
            <div class="rounded-4xl bg-[#F5F5F7] aspect-3/4 sm:aspect-4/3 flex items-center justify-center p-6 sm:p-8 overflow-hidden">
              <div class="h-full aspect-12/25 rounded-2xl overflow-hidden shadow-[0_20px_40px_rgba(0,0,0,0.1)] border border-black/5 bg-white relative">
                <video class="w-full h-full object-cover" autoplay muted playsinline loop poster={`${import.meta.env.BASE_URL}videos/step4-poster.svg`}>
                  <source src={`${import.meta.env.BASE_URL}videos/step4.mp4`} type="video/mp4" />
                </video>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Download Section (Dark Mode) -->
  <section id="download" class="py-24 sm:py-32 bg-[#111111] text-white">
    <div class="max-w-6xl mx-auto px-6">
      <div class="text-center mb-16 reveal-up">
        <h2 class="text-4xl sm:text-6xl font-bold tracking-tight">现在就开始</h2>
        <p class="mt-6 text-xl text-white/60 font-medium">免费开源，选择你的平台。</p>
        <div class="mt-6 inline-flex items-center gap-3 rounded-full border border-white/10 bg-white/5 px-5 py-2 text-sm font-medium text-white/80">
          <span class="text-white/50">最新版本</span>
          <span id="release-version" data-fallback-version={fallbackVersion} class="text-white">{fallbackVersion}</span>
          <span class="text-white/30">·</span>
          <span id="release-date" class="text-white/50"></span>
        </div>
      </div>

      <!-- Source Toggle -->
      <div class="flex justify-center mb-16 reveal-up" style="transition-delay: 100ms;">
        <div class="inline-flex items-center bg-white/10 rounded-full p-1 border border-white/5 backdrop-blur-md" id="source-toggle">
          <button data-source="github" class="source-btn px-6 py-2.5 rounded-full text-sm font-semibold transition-all text-white/60 hover:text-white">GitHub</button>
          <button data-source="gitee" class="source-btn px-6 py-2.5 rounded-full text-sm font-semibold transition-all bg-white text-black shadow-sm">Gitee (国内推荐)</button>
        </div>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 sm:gap-6 mx-auto reveal-up" style="transition-delay: 200ms;">
        <!-- Android -->
        <div class="flex flex-col items-center gap-6 p-10 rounded-4xl bg-white/5 border border-white/10 hover:bg-white/10 transition-colors">
