  <!-- Global styles for animations -->
  <style is:global>
    .reveal-up {
      opacity: 0;
      transform: translateY(30px) scale(0.98);
      transition: all 1s cubic-bezier(0.16, 1, 0.3, 1);
    }
    .reveal-up.active {
      opacity: 1;
      transform: translateY(0) scale(1);
    }
  </style>

  <!-- Scripts -->
  <script>
    // Reveal up animation observer
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('active');
          observer.unobserve(entry.target);
        }
      });
    }, { threshold: 0.1, rootMargin: "0px 0px -50px 0px" });

    document.querySelectorAll('.reveal-up').forEach((el) => {
      observer.observe(el);
    });

    // Nav blur background transition
    const nav = document.querySelector('nav');
    window.addEventListener('scroll', () => {
      if (window.scrollY > 20) {
        nav?.classList.add('shadow-sm', 'bg-white/80');
        nav?.classList.remove('bg-white/70');
      } else {
        nav?.classList.remove('shadow-sm', 'bg-white/80');
        nav?.classList.add('bg-white/70');
      }
    });

    // Download links script
    const GITHUB_RELEASE = 'https://github.com/IT-Bill/BiCone/releases/latest';
    const GITEE_RELEASE = 'https://gitee.com/IT-Bill/BiCone/releases/latest';
    const GITHUB_API = 'https://api.github.com/repos/IT-Bill/BiCone/releases/latest';

    interface Asset { name: string; browser_download_url: string; size: number; }
    interface Release { tag_name: string; published_at: string; assets: Asset[]; }

    function formatSize(bytes: number): string {
      const mb = bytes / (1024 * 1024);
      return mb >= 1 ? `${mb.toFixed(1)} MB` : `${(bytes / 1024).toFixed(0)} KB`;
    }

    let currentSource = 'gitee';
    let releaseData: Release | null = null;

    const toggle = document.getElementById('source-toggle');
    const buttons = toggle?.querySelectorAll<HTMLButtonElement>('.source-btn') ?? [];
    const links = document.querySelectorAll<HTMLAnchorElement>('.download-link');
    const releaseVersion = document.getElementById('release-version');

    function normalizeVersionLabel(version: string | null | undefined): string {
      if (!version) {
        return releaseVersion?.getAttribute('data-fallback-version') ?? '0.0.0';
      }

      return version.startsWith('v') ? version : `v${version}`;
    }

    function updateVersion() {
      if (!releaseVersion) {
        return;
      }

      releaseVersion.textContent = normalizeVersionLabel(releaseData?.tag_name);

      const releaseDateEl = document.getElementById('release-date');
      if (releaseDateEl && releaseData?.published_at) {
        const date = new Date(releaseData.published_at);
        releaseDateEl.textContent = `${date.getFullYear()}-${String(date.getMonth() + 1).padStart(2, '0')}-${String(date.getDate()).padStart(2, '0')}`;
      }
    }

    async function fetchRelease() {
      try {
        const res = await fetch(GITHUB_API);
        if (res.ok) {
          releaseData = await res.json();
          updateVersion();
          updateLinks();
        }
      } catch {
        // Silently fail
      }
    }

    function getDownloadUrl(fileSuffix: string): string {
      if (currentSource === 'gitee') {
        if (releaseData) {
          const asset = releaseData.assets.find((a) => a.name.endsWith(fileSuffix));
          if (asset) {
            return `https://gitee.com/IT-Bill/BiCone/releases/download/${releaseData.tag_name}/${asset.name}`;
          }
        }
        return GITEE_RELEASE;
      }
      if (releaseData) {
        const asset = releaseData.assets.find((a) => a.name.endsWith(fileSuffix));
        if (asset) return asset.browser_download_url;
      }
      return GITHUB_RELEASE;
    }

    function getAssetSize(fileSuffix: string): number | null {
      if (!releaseData) return null;
      const asset = releaseData.assets.find((a) => a.name.endsWith(fileSuffix));
      return asset?.size ?? null;
    }

    function updateLinks() {
      links.forEach((link) => {
        const fileSuffix = link.getAttribute('data-file');
        if (fileSuffix) {
          link.setAttribute('href', getDownloadUrl(fileSuffix));
          // Update size badge
          let sizeEl = link.querySelector('.file-size');
          const size = getAssetSize(fileSuffix);
          if (size) {
            if (!sizeEl) {
              sizeEl = document.createElement('span');
              sizeEl.className = 'file-size opacity-60 text-xs';
              link.appendChild(sizeEl);
            }
            sizeEl.textContent = formatSize(size);
          } else if (sizeEl) {
            sizeEl.remove();
          }
        }
      });
    }

    function updateButtons() {
      buttons.forEach((btn) => {
        if (btn.getAttribute('data-source') === currentSource) {
          btn.classList.add('bg-white', 'text-black');
          btn.classList.remove('text-white/60', 'hover:text-white', 'bg-transparent');
          btn.classList.add('shadow-sm');
        } else {
          btn.classList.remove('bg-white', 'text-black', 'shadow-sm');
          btn.classList.add('text-white/60', 'hover:text-white', 'bg-transparent');
        }
      });
    }

    buttons.forEach((btn) => {
      btn.addEventListener('click', () => {
        currentSource = btn.getAttribute('data-source') || 'github';
        updateButtons();
        updateLinks();
      });
    });

    updateVersion();
    updateButtons();
    updateLinks();
    fetchRelease();
  </script>

